# Matches docker-compose.yml (npm run docker:up). Override if using another Postgres.
DATABASE_URL="postgresql://pyramidadmin:pyramid123@localhost:5432/pyramid?schema=public"
JWT_SECRET="replace-with-long-random-string"
JWT_EXPIRES_IN="7d"

# Optional: prisma db seed default passwords
SEED_ADMIN_PASSWORD="ChangeMe123!"

# Required for POST /auth/register/admin (disabled if unset)
ADMIN_REGISTRATION_SECRET="replace-with-long-random-secret"

# Required for POST /auth/register/student (disabled if unset)
STUDENT_REGISTRATION_CODE="replace-with-shared-admissions-code"

# Comma-separated browser origins allowed to call this API (CORS). If unset, dev defaults
# include localhost ports 3000–3002 (marketing site often runs on 3002).
# FRONTEND_ORIGIN=http://localhost:3002,http://localhost:3001

# Local file uploads (POST /files/upload). Served at FILES_PUBLIC_PREFIX.
FILES_UPLOAD_DIR="uploads"
FILES_PUBLIC_PREFIX="/files"
# Max upload size in bytes (default 26214400 = 25 MiB if unset; used for admin uploads + public apply PDFs)
# FILES_MAX_BYTES=26214400
